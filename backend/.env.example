# Configuração do banco (SQL Server - Autenticação do Windows)
DB_SERVER=192.168.250.8,61433
DB_DATABASE=OPED_FC
# Deixe em branco para usar o driver ODBC detectado automaticamente,
# ou force um nome específico, ex: ODBC Driver 18 for SQL Server
DB_ODBC_DRIVER=

# Segurança
JWT_SECRET=troque-este-segredo-por-uma-string-longa-e-aleatoria
JWT_EXPIRES=7d

# Servidor
PORT=4000
# Origem permitida do frontend (Vite)
CORS_ORIGIN=http://localhost:5180
