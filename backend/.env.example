# Configuração do banco (Postgres - Neon)
DATABASE_URL=postgresql://usuario:senha@host-pooler.regiao.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Segurança
JWT_SECRET=troque-este-segredo-por-uma-string-longa-e-aleatoria
JWT_EXPIRES=7d

# Servidor
PORT=4000
# Origem permitida do frontend (Vite)
# Separe múltiplas origens por vírgula (ex.: localhost + IP da rede local)
CORS_ORIGIN=http://localhost:5180,http://192.168.0.10:5180
